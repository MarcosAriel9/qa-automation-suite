# Copiar a ".env" — config general del servidor. Las credenciales/URLs por ambiente van
# aparte en ".env.dev" y ".env.prod" (copiar desde ".env.dev.example" / ".env.prod.example").

PORT=3500
# false = navegador visible (necesario para escanear el QR de Venta con el celular)
HEADLESS=false
DEFAULT_TIMEOUT_MS=30000
# Tiempo maximo esperando que el usuario escanee el QR y el banco confirme el cobro
QR_WAIT_TIMEOUT_MS=180000
# Tiempo maximo esperando que el backend genere la cotizacion (proceso asincrono, "puede tomar unos minutos")
COTIZACION_WAIT_TIMEOUT_MS=150000
