# Copiar este archivo a ".env" y llenar con datos reales. Nunca commitear ".env".

# --- Servidor ---
PORT=3500
# false = navegador visible (necesario para escanear el QR de Venta con el celular)
HEADLESS=false
DEFAULT_TIMEOUT_MS=30000
# Tiempo maximo esperando que el usuario escanee el QR y el banco confirme el cobro
QR_WAIT_TIMEOUT_MS=180000
# Tiempo maximo esperando que el backend genere la cotizacion (proceso asincrono, "puede tomar unos minutos")
COTIZACION_WAIT_TIMEOUT_MS=150000

# --- POS ---
POS_DEV_BASE_URL=https://pos.gs-baz-credito.com
POS_PROD_BASE_URL=https://pos.bazcredito.mx
POS_USER=
POS_PASSWORD=
POS_CLIENTE_UNICO=
# Producto manual capturado en Cotizador ("Agregar otros productos"), no se elige del inventario
POS_COTIZADOR_PRODUCTO_NOMBRE=motofake
POS_COTIZADOR_PRODUCTO_PRECIO=600
POS_VENTA_MONTO=100
POS_SUCURSAL=
POS_CAJA=
# SKU/serie de un producto existente en el ambiente, usado para el front de Etiquetas
POS_ETIQUETA_SKU=

# --- Admin ---
ADMIN_DEV_BASE_URL=https://admin.gs-baz-credito.com
ADMIN_PROD_BASE_URL=https://admin.bazcredito.mx
ADMIN_USER=
ADMIN_PASSWORD=
