# Copiar a ".env.dev" y llenar con datos reales del ambiente de Dev. Nunca commitear ".env.dev".
# OJO: si una contraseña empieza con "#" (o lo contiene tras un espacio), dotenv la trata como
# un comentario y la carga vacía sin avisar. Si tu contraseña tiene "#", ponla entre comillas:
# POS_PASSWORD="#miClave123"

# --- POS ---
POS_BASE_URL=https://pos.gs-baz-credito.com
POS_USER=
POS_PASSWORD=
POS_CLIENTE_UNICO=
# Producto manual capturado en Cotizador ("Agregar otros productos"), no se elige del inventario
POS_COTIZADOR_PRODUCTO_NOMBRE=motofake
POS_COTIZADOR_PRODUCTO_PRECIO=600
POS_VENTA_MONTO=100
POS_SUCURSAL=
POS_CAJA=
# SKU/serie de un producto existente en el ambiente, usado para el front de Etiquetas
POS_ETIQUETA_SKU=

# --- Admin ---
ADMIN_BASE_URL=https://admin.gs-baz-credito.com
ADMIN_USER=
ADMIN_PASSWORD=
