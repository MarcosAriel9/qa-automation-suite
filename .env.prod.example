# Copiar a ".env.prod" y llenar con datos reales de Producción. Nunca commitear ".env.prod".
# OJO: el front "Venta" de POS genera un cobro real en Producción (el formulario web pide
# una confirmación extra antes de correrlo).

# --- POS ---
POS_BASE_URL=https://pos.bazcredito.mx
POS_USER=
POS_PASSWORD=
POS_CLIENTE_UNICO=
# Producto manual capturado en Cotizador ("Agregar otros productos"), no se elige del inventario
POS_COTIZADOR_PRODUCTO_NOMBRE=motofake
POS_COTIZADOR_PRODUCTO_PRECIO=600
POS_VENTA_MONTO=
POS_SUCURSAL=
POS_CAJA=
# SKU/serie de un producto existente en el ambiente, usado para el front de Etiquetas
POS_ETIQUETA_SKU=

# --- Admin ---
ADMIN_BASE_URL=https://admin.bazcredito.mx
ADMIN_USER=
ADMIN_PASSWORD=
